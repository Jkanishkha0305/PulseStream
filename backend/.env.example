# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key


# CORS
CORS_ORIGINS=http://localhost:3000

# Pipeline Configuration
DATA_DIR=./data
N_PATIENTS=10
WINDOW_SIZE=30
